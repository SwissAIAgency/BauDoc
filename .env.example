APP_NAME="Baufortschritt Dokumentation"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000/api

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=baufortschritt
DB_USERNAME=baufortschritt
DB_PASSWORD=change-me

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

FILESYSTEM_DISK=s3
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=baufortschritt-local
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_USE_PATH_STYLE_ENDPOINT=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@example.local
MAIL_FROM_NAME="Baufortschritt Dokumentation"

AI_FEATURES_ENABLED=false
